{
   "name": "saby-i18n",
   "version": "20.3200.0",
   "repository": {
      "type": "git",
      "url": "git@github.com:saby/i18n.git"
   },
   "files": [
      "I18n/*"
   ],
   "scripts": {
      "build": "npm run build:typescript && npm run build:compile",
      "build:typescript": "saby-typescript --install --tsconfig=tsconfig.base.json",
      "build:compile": "saby-units --install && npm run builder",
      "start": "node node_modules/saby-units/cli/server",
      "test": "saby-units %NODE_DEBUG_OPTION% --isolated",
      "test:node": "saby-units --isolated --report",
      "test:node-coverage": "saby-units --isolated --coverage --report",
      "test:browser": "saby-units --browser --report",
      "test:browser-coverage": "saby-units --browser --report --coverage",
      "builder": "node node_modules/gulp/bin/gulp.js --gulpfile=node_modules/sbis3-builder/gulpfile.js build --config=../../builderConfig.json --log-level=warning -LLLL"
   },
   "saby-units": {
      "moduleType": "amd",
      "tests": "I18nTest",
      "root": "application",
      "url": {
         "port": 1025
      }
   },
   "nyc": {
      "include": [
         "application/I18n/**/*.js"
      ],
      "reporter": [
         "text",
         "html"
      ],
      "cache": false,
      "eager": true,
      "report-dir": "./artifacts/coverage"
   },
   "dependencies": {
      "@types/node": "^11.9.4",
      "@types/requirejs": "^2.1.31"
   },
   "devDependencies": {
      "@tensor-corp/eslint-config": "^2.0.7",
      "eslint": "^5.13.0",
      "rmi": "git+https://git.sbis.ru/sbis/rmi.git#rc-20.3200",
      "saby-typescript": "git+https://platform-git.sbis.ru/saby/TypeScript.git#rc-20.3200",
      "saby-units": "git+https://platform-git.sbis.ru/saby/Units.git#rc-20.3200",
      "saby-types": "git+https://platform-git.sbis.ru/saby/Types.git#rc-20.3200",
      "sbis3-ws": "git+https://git.sbis.ru/sbis/ws.git#rc-20.3200",
      "sbis3-builder": "git+https://platform-git.sbis.ru/saby/Builder.git#rc-20.3200",
      "wasaby-app": "git+https://platform-git.sbis.ru/saby/wasaby-app.git#rc-20.3200"
   }
}